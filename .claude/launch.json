{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "api",
      "runtimeExecutable": "uvicorn",
      "runtimeArgs": ["app.main:app", "--host", "0.0.0.0", "--port", "8000", "--reload"],
      "port": 8000
    },
    {
      "name": "streamlit",
      "runtimeExecutable": "streamlit",
      "runtimeArgs": ["run", "streamlit_app.py", "--server.port", "8501"],
      "port": 8501
    }
  ]
}
